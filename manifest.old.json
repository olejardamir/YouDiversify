{
  "manifest_version": 3,
  "name": "YouDiversify",
  "version": "0.7.0",
  "description": "Starts paused until dislike status is visible, then skips downvoted videos or resumes playback.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "YouDiversify: ON"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
